# =========================================
# Darshan Ticket Booking App - Environment Variables
# Copy this file to ".env" and fill in your actual values.
# NEVER commit the real ".env" file to GitHub.
# =========================================

# Server
PORT=5000
NODE_ENV=development

# ---- MongoDB Configuration ----
# Option 1: Local MongoDB (make sure `mongod` service is running)
MONGO_URI=mongodb://localhost:27017/darshan_booking_db

# Option 2: MongoDB Atlas (cloud) - example format, replace with your own cluster info
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/darshan_booking_db?retryWrites=true&w=majority

# JWT (used later by auth module, kept here so config stays centralized)
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRE=7d
